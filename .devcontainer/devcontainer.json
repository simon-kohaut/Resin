// For format details, see https://aka.ms/devcontainer.json.
{
	"name": "resin-devcontainer",

    "build": {
	    "dockerfile": "../Dockerfile"
    },

	"workspaceMount": "source=${localWorkspaceFolder},target=/Resin,type=bind",
	"workspaceFolder": "/Resin",

	"customizations": {
		"vscode": {
			"extensions": [
				"rust-lang.rust-analyzer",
				"redhat.vscode-yaml",
				"ms-iot.vscode-ros"
			]
		}
	},

	"containerEnv": {
        "CLINGO_LIBRARY_PATH": "/usr/lib",
        "LD_LIBRARY_PATH": "/usr/lib"
    }
}
